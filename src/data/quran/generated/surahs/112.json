[{"verseKey":"112:1","arabicIndopak":"قُلْ هُوَ اللّٰهُ اَحَدٌ ۝١ۚ","transliterationEn":"Qul huwal laahu ahad","translationBnTaisirul":"বল, তিনি আল্লাহ, এক অদ্বিতীয়,"},{"verseKey":"112:2","arabicIndopak":"اَللّٰهُ الصَّمَدُ ۝٢ۚ","transliterationEn":"Allah-hus samad","translationBnTaisirul":"আল্লাহ কোন কিছুর মুখাপেক্ষী নন, সবই তাঁর মুখাপেক্ষী,"},{"verseKey":"112:3","arabicIndopak":"لَمْ يَلِدْ࣢ۙ وَلَمْ يُوْلَدْ ۝٣ۙ","transliterationEn":"Lam yalid Wa-lam yoolad","translationBnTaisirul":"তিনি কাউকে জন্ম দেন না, আর তাঁকেও জন্ম দেয়া হয়নি।"},{"verseKey":"112:4","arabicIndopak":"وَلَمْ يَكُنْ لَّهٗ كُفُوًا اَحَدٌ ۝٤ࣖ","transliterationEn":"Wa-lam yakul lahoo kufuwan ahad","translationBnTaisirul":"তাঁর সমকক্ষ কেউ নয়।"}]
