[{"verseKey":"87:1","arabicIndopak":"سَبِّحِ اسْمَ رَبِّكَ الْاَعْلَي ۝١ۙ","transliterationEn":"Sabbihis ma Rabbikal A'laa","translationBnTaisirul":"তোমার মহান প্রতিপালকের নামের পবিত্রতা ও মহিমা ঘোষণা কর।"},{"verseKey":"87:2","arabicIndopak":"الَّذِيْ خَلَقَ فَسَوّٰي ۝٢ࣕۙ","transliterationEn":"Allazee khalaqa fasawwaa","translationBnTaisirul":"যিনি সৃষ্টি করেছেন অতঃপর করেছেন (দেহের প্রতিটি অঙ্গকে) সামঞ্জস্যপূর্ণ।"},{"verseKey":"87:3","arabicIndopak":"وَالَّذِيْ قَدَّرَ فَهَدٰي ۝٣ࣕۙ","transliterationEn":"Wallazee qaddara fahadaa","translationBnTaisirul":"যিনি সকল বস্তুকে পরিমাণ মত সৃষ্টি করেছেন, অতঃপর (জীবনে চলার) পথনির্দেশ করেছেন।"},{"verseKey":"87:4","arabicIndopak":"وَالَّذِيْٓ اَخْرَجَ الْمَرْعٰي ۝٤ࣕۙ","transliterationEn":"Wallazeee akhrajal mar'aa","translationBnTaisirul":"যিনি তৃণ ইত্যাদি বের করেছেন।"},{"verseKey":"87:5","arabicIndopak":"فَجَعَلَهٗ غُثَا࢜ءً اَحْوٰي ۝٥ؕ","transliterationEn":"Faja'alahoo ghusaaa'an ahwaa","translationBnTaisirul":"অতঃপর তাকে কাল আবর্জনায় পরিণত করেছেন।"},{"verseKey":"87:6","arabicIndopak":"سَنُقْرِي͏ٔ͏ُكَ فَلَا تَنْسٰٓي ۝٦ۙ","transliterationEn":"Sanuqri'uka falaa tansaaa","translationBnTaisirul":"আমি তোমাকে পড়িয়ে দেব, যার ফলে তুমি ভুলে যাবে না।"},{"verseKey":"87:7","arabicIndopak":"اِلَّا مَا شَا࢜ءَ اللّٰهُؕ اِنَّهٗ يَعْلَمُ الْجَهْرَ وَمَا يَخْفٰي ۝٧ؕ","transliterationEn":"Illaa maa shaaa'al laah; innahoo ya'lamul jahra Wa-maa yakhfaa","translationBnTaisirul":"তবে ওটা বাদে যেটা আল্লাহ (রহিত করার) ইচ্ছে করবেন। তিনি জানেন যা প্রকাশ্য আর যা গোপন।"},{"verseKey":"87:8","arabicIndopak":"وَنُيَسِّرُكَ لِلْيُسْرٰي ۝٨ۚۖ","transliterationEn":"Wa-nu-yassiruka lilyusraa","translationBnTaisirul":"আমি তোমার জন্য সহজপথ (অনুসরণ করা) আরো সহজ করে দেব।"},{"verseKey":"87:9","arabicIndopak":"فَذَكِّرْ اِنْ نَّفَعَتِ الذِّكْرٰي ۝٩ؕ","transliterationEn":"Fazakkir in nafa'atiz zikraa","translationBnTaisirul":"কাজেই তুমি উপদেশ দাও যদি উপদেশ উপকার দেয়।"},{"verseKey":"87:10","arabicIndopak":"سَيَذَّكَّرُ مَنْ يَّخْشٰي ۝١٠ۙ","transliterationEn":"Sa-yazzakkaru mai yakhshaa","translationBnTaisirul":"যে ভয় করে সে উপদেশ গ্রহণ করবে।"},{"verseKey":"87:11","arabicIndopak":"وَيَتَجَنَّبُهَا الْاَشْقَي ۝١١ۙ","transliterationEn":"Wa-yatajannabuhal ashqaa","translationBnTaisirul":"আর তা উপেক্ষা করবে যে চরম হতভাগা।"},{"verseKey":"87:12","arabicIndopak":"الَّذِيْ يَصْلَي النَّارَ الْكُبْرٰي ۝١٢ۚ","transliterationEn":"Allazee yaslan Naaral kubraa","translationBnTaisirul":"যে ভয়াবহ আগুনে প্রবেশ করবে।"},{"verseKey":"87:13","arabicIndopak":"ثُمَّ لَا يَمُوْتُ فِيْهَا وَلَا يَحْيٰي ۝١٣ؕ","transliterationEn":"Summa laa yamootu feehaa Wa-laa yahyaa","translationBnTaisirul":"অতঃপর সেখানে সে না (মরার মত) মরবে, আর না (বাঁচার মত) বাঁচবে।"},{"verseKey":"87:14","arabicIndopak":"قَدْ اَفْلَحَ مَنْ تَزَكّٰي ۝١٤ۙ","transliterationEn":"Qad aflaha man tazakkaa","translationBnTaisirul":"সাফল্য লাভ করবে সে যে নিজেকে পরিশুদ্ধ করে,"},{"verseKey":"87:15","arabicIndopak":"وَذَكَرَ اسْمَ رَبِّهٖ فَصَلّٰي ۝١٥ؕ","transliterationEn":"Wa-zakaras ma Rabbihee fasallaa","translationBnTaisirul":"আর তার প্রতিপালকের নাম স্মরণ করে ও নামায কায়েম করে।"},{"verseKey":"87:16","arabicIndopak":"بَلْ تُو͏ٔ͏ْثِرُوْنَ الْحَيٰوةَ الدُّنْيَا ۝١٦ۚۖ","transliterationEn":"Bal tu'siroonal hayaatad dunyaa","translationBnTaisirul":"কিন্তু তোমরা তো দুনিয়ার জীবনকেই প্রাধান্য দাও,"},{"verseKey":"87:17","arabicIndopak":"وَالْاٰخِرَةُ خَيْرٌ وَّاَبْقٰي ۝١٧ؕ","transliterationEn":"Wal-Aakhiratu khairunw Wa-abqaa","translationBnTaisirul":"অথচ আখিরাতই অধিক উৎকৃষ্ট ও স্থায়ী।"},{"verseKey":"87:18","arabicIndopak":"اِنَّ هٰذَا لَفِي الصُّحُفِ الْاُوْلٰي ۝١٨ۙ","transliterationEn":"Inna haazaa lafis suhu-fil oolaa","translationBnTaisirul":"আগের কিতাবগুলোতে এ কথা (লিপিবদ্ধ) আছে,"},{"verseKey":"87:19","arabicIndopak":"صُحُفِ اِبْرٰهِيْمَ وَمُوْسٰي ۝١٩ࣖ","transliterationEn":"Suhufi Ibraaheema Wa-Moosaa","translationBnTaisirul":"ইবরাহীম ও মূসার কিতাবে।"}]
