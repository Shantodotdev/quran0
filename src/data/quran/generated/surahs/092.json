[{"verseKey":"92:1","arabicIndopak":"وَالَّيْلِ اِذَا يَغْشٰي ۝١ۙ","transliterationEn":"Wallaili izaa yaghshaa","translationBnTaisirul":"শপথ রাতের যখন তা (আলোকে) ঢেকে দেয়,"},{"verseKey":"92:2","arabicIndopak":"وَالنَّهَارِ اِذَا تَجَلّٰي ۝٢ۙ","transliterationEn":"Wannahaari izaa tajalla","translationBnTaisirul":"শপথ দিনের যখন তা উদ্ভাসিত হয়ে উঠে।"},{"verseKey":"92:3","arabicIndopak":"وَمَا خَلَقَ الذَّكَرَ وَالْاُنْثٰٓي ۝٣ۙ","transliterationEn":"Wa-maa khalaqaz zakara wal-unthaa","translationBnTaisirul":"আর শপথ তাঁর যিনি সৃষ্টি করেছেন পুরুষ ও নারী,"},{"verseKey":"92:4","arabicIndopak":"اِنَّ سَعْيَكُمْ لَشَتّٰي ۝٤ؕ","transliterationEn":"Inna sa'yakum lashattaa","translationBnTaisirul":"তোমাদের চেষ্টা সাধনা অবশ্যই বিভিন্নমুখী।"},{"verseKey":"92:5","arabicIndopak":"فَاَمَّا مَنْ اَعْطٰي وَاتَّقٰي ۝٥ۙ","transliterationEn":"Fa-ammaa man a'taa wattaqaa","translationBnTaisirul":"অতএব যে ব্যক্তি (আল্লাহর সন্তুষ্টির জন্য) দান করে ও (আল্লাহকে) ভয় করে,"},{"verseKey":"92:6","arabicIndopak":"وَصَدَّقَ بِالْحُسْنٰي ۝٦ۙ","transliterationEn":"Wa-saddaqa bil-husnaa","translationBnTaisirul":"এবং উত্তম বিষয়কে সত্য মনে করে,"},{"verseKey":"92:7","arabicIndopak":"فَسَنُيَسِّرُهٗ لِلْيُسْرٰي ۝٧ؕ","transliterationEn":"Fasanu-yassiruhoo lilyusraa","translationBnTaisirul":"আমি তার জন্য সহজ পথে চলা সহজ করে দেব।"},{"verseKey":"92:8","arabicIndopak":"وَاَمَّا مَنْۢ بَخِلَ وَاسْتَغْنٰي ۝٨ۙ","transliterationEn":"Wa-ammaa man bakhila wastaghnaa","translationBnTaisirul":"আর যে ব্যক্তি কৃপণতা করে আর (আল্লাহর প্রতি) বেপরোয়া হয়,"},{"verseKey":"92:9","arabicIndopak":"وَكَذَّبَ بِالْحُسْنٰي ۝٩ۙ","transliterationEn":"Wa-kazzaba bil-husnaa","translationBnTaisirul":"আর যা উত্তম তা অমান্য করে,"},{"verseKey":"92:10","arabicIndopak":"فَسَنُيَسِّرُهٗ لِلْعُسْرٰي ۝١٠ؕ","transliterationEn":"Fasanu-yassiruhoo lil'usraa","translationBnTaisirul":"আমি তার জন্য কঠিন পথ (অর্থাৎ অন্যায়, অসত্য, হিংসা ও হানাহানির পথ) সহজ করে দিব।"},{"verseKey":"92:11","arabicIndopak":"وَمَا يُغْنِيْ عَنْهُ مَالُهٗٓ اِذَا تَرَدّٰي ۝١١ؕ","transliterationEn":"Wa-maa yughnee 'anhu maaluhooo izaa taraddaa","translationBnTaisirul":"যখন সে ধ্বংস হবে (অর্থাৎ মরবে) তখন তার (সঞ্চিত) ধন-সম্পদ কোনই কাজে আসবে না।"},{"verseKey":"92:12","arabicIndopak":"اِنَّ عَلَيْنَا لَلْهُدٰي ۝١٢ؗۖ","transliterationEn":"Inna 'alainaa lal-hudaa","translationBnTaisirul":"সঠিক পথ দেখানো অবশ্যই আমারই কাজ"},{"verseKey":"92:13","arabicIndopak":"وَاِنَّ لَنَا لَلْاٰخِرَةَ وَالْاُوْلٰي ۝١٣","transliterationEn":"Wa-inna lanaa lal-Aakhirata wal-oolaa","translationBnTaisirul":"আর পরকাল ও ইহকালের একমাত্র মালিক আমি।"},{"verseKey":"92:14","arabicIndopak":"فَاَنْذَرْتُكُمْ نَارًا تَلَظّٰي ۝١٤ۚ","transliterationEn":"Fa-anzartukum naaran talazzaa","translationBnTaisirul":"কাজেই আমি তোমাদেরকে দাউ দাউ ক’রে জ্বলা আগুন সম্পর্কে সতর্ক করে দিচ্ছি।"},{"verseKey":"92:15","arabicIndopak":"لَا يَصْلٰىهَا͏ٓ اِلَّا الْاَشْقَي ۝١٥ۙ","transliterationEn":"Laa yaslaahaaa illal ashqaa","translationBnTaisirul":"চরম হতভাগা ছাড়া কেউ তাতে প্রবেশ করবে না।"},{"verseKey":"92:16","arabicIndopak":"الَّذِيْ كَذَّبَ وَتَوَلّٰي ۝١٦ؕ","transliterationEn":"Allazee kazzaba Wa-tawallaa","translationBnTaisirul":"যে অস্বীকার করে ও মুখ ফিরিয়ে নেয়"},{"verseKey":"92:17","arabicIndopak":"وَسَيُجَنَّبُهَا الْاَتْقَي ۝١٧ۙ","transliterationEn":"Wa-sa-yujannnabuhal atqaa","translationBnTaisirul":"তাত্থেকে দূরে রাখা হবে এমন ব্যক্তিকে যে আল্লাহকে খুব বেশি ভয় করে,"},{"verseKey":"92:18","arabicIndopak":"الَّذِيْ يُو͏ٔ͏ْتِيْ مَالَهٗ يَتَزَكّٰي ۝١٨ۚ","transliterationEn":"Allazee yu'tee maalahoo yatazakkaa","translationBnTaisirul":"যে পবিত্রতা অর্জনের উদ্দেশ্যে নিজের ধন-সম্পদ দান করে,"},{"verseKey":"92:19","arabicIndopak":"وَمَا لِاَحَدٍ عِنْدَهٗ مِنْ نِّعْمَةٍ تُجْزٰٓي ۝١٩ۙ","transliterationEn":"Wa-maa li-ahadin 'indahoo min ni'matin tujzaaa","translationBnTaisirul":"(সে দান করে) তার প্রতি কারো অনুগ্রহের প্রতিদান হিসেবে নয়,"},{"verseKey":"92:20","arabicIndopak":"اِلَّا ابْتِغَا࢜ءَ وَجْهِ رَبِّهِ الْاَعْلٰي ۝٢٠ۚ","transliterationEn":"Illab tighaaa'a wajhi rabbihil a-'laa","translationBnTaisirul":"একমাত্র তার মহান প্রতিপালকের চেহারা (সন্তোষ) লাভের আশায়।"},{"verseKey":"92:21","arabicIndopak":"وَلَسَوْفَ يَرْضٰي ۝٢١ࣖ","transliterationEn":"Wa-lasawfa yardaa","translationBnTaisirul":"সে অবশ্যই অতি শীঘ্র (আল্লাহর নি‘মাত পেয়ে) সন্তুষ্ট হয়ে যাবে।"}]
