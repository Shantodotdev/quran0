[{"verseKey":"93:1","arabicIndopak":"وَالضُّحٰي ۝١ۙ","transliterationEn":"Wad-duhaa","translationBnTaisirul":"সকালের উজ্জ্বল আলোর শপথ,"},{"verseKey":"93:2","arabicIndopak":"وَالَّيْلِ اِذَا سَجٰي ۝٢ۙ","transliterationEn":"Wal-laili iza sajaa","translationBnTaisirul":"রাতের শপথ যখন তা হয় শান্ত-নিঝুম,"},{"verseKey":"93:3","arabicIndopak":"مَا وَدَّعَكَ رَبُّكَ وَمَا قَلٰي ۝٣ؕ","transliterationEn":"Ma wad-da'aka rabbuka Wa-ma qalaa","translationBnTaisirul":"তোমার প্রতিপালক তোমাকে কক্ষনো পরিত্যাগ করেননি, আর তিনি অসন্তুষ্টও নন।"},{"verseKey":"93:4","arabicIndopak":"وَلَلْاٰخِرَةُ خَيْرٌ لَّكَ مِنَ الْاُوْلٰي ۝٤ؕ","transliterationEn":"Walal-aakhiratu khairul laka minal oola","translationBnTaisirul":"অবশ্যই পরবর্তী সময় পূর্ববর্তী সময়ের চেয়ে তোমার জন্য হবে অধিক উৎকৃষ্ট।"},{"verseKey":"93:5","arabicIndopak":"وَلَسَوْفَ يُعْطِيْكَ رَبُّكَ فَتَرْضٰي ۝٥ؕ","transliterationEn":"Wa-la-sawfa y'uteeka rabbuka fatarda","translationBnTaisirul":"শীঘ্রই তোমার প্রতিপালক তোমাকে (এত নি‘মাত) দিবেন যার ফলে তুমি সন্তুষ্ট হয়ে যাবে।"},{"verseKey":"93:6","arabicIndopak":"اَلَمْ يَجِدْكَ يَتِيْمًا فَاٰوٰي ۝٦ࣕ","transliterationEn":"Alam ya-jidka yateeman fa-aawaa","translationBnTaisirul":"তিনি কি তোমাকে ইয়াতীম অবস্থায় পান নাই? অতঃপর তিনি আশ্রয় দিয়েছেন।"},{"verseKey":"93:7","arabicIndopak":"وَوَجَدَكَ ضَا࢜لًّا فَهَدٰي ۝٧ࣕ","transliterationEn":"Wa-Wa-jadaka daal-lan fahada","translationBnTaisirul":"তিনি তোমাকে পেয়েছিলেন পথের দিশা-হীন, অতঃপর দেখালেন সঠিক পথ।"},{"verseKey":"93:8","arabicIndopak":"وَوَجَدَكَ عَا࢜ىِٕلًا فَاَغْنٰي ۝٨ؕ","transliterationEn":"Wa-Wa-jadaka 'aa-ilan fa-aghnaa","translationBnTaisirul":"তিনি তোমাকে পেলেন নিঃস্ব, অতঃপর করলেন অভাবমুক্ত।"},{"verseKey":"93:9","arabicIndopak":"فَاَمَّا الْيَتِيْمَ فَلَا تَقْهَرْ ۝٩ؕ","transliterationEn":"Fa-am-mal yateema fala taqhar","translationBnTaisirul":"কাজেই তুমি ইয়াতীমের প্রতি কঠোরতা করবে না।"},{"verseKey":"93:10","arabicIndopak":"وَاَمَّا السَّا࢜ىِٕلَ فَلَا تَنْهَرْ ۝١٠ؕ","transliterationEn":"Wa-am-mas saa-ila fala tanhar","translationBnTaisirul":"এবং ভিক্ষুককে ধমক দিবে না।"},{"verseKey":"93:11","arabicIndopak":"وَاَمَّا بِنِعْمَةِ رَبِّكَ فَحَدِّثْ ۝١١ࣖ","transliterationEn":"Wa-amma bi-ni'mati rabbika fahad-dith","translationBnTaisirul":"আর তুমি তোমার রব-এর নি‘মাতকে (তোমার কথা, কাজকর্ম ও আচরণের মাধ্যমে) প্রকাশ করতে থাক।"}]
