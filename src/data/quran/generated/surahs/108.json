[{"verseKey":"108:1","arabicIndopak":"اِنَّا͏ٓ اَعْطَيْنٰكَ الْكَوْثَرَ ۝١ؕ","transliterationEn":"Innaaa a'tainaa-kal kauthar","translationBnTaisirul":"আমি তোমাকে (হাওযে) কাওসার দান করেছি।"},{"verseKey":"108:2","arabicIndopak":"فَصَلِّ لِرَبِّكَ وَانْحَرْ ۝٢ؕ","transliterationEn":"Fasalli li-rabbika wanhar","translationBnTaisirul":"কাজেই তুমি তোমার প্রতিপালকের উদ্দেশ্যে নামায আদায় কর এবং কুরবানী কর,"},{"verseKey":"108:3","arabicIndopak":"اِنَّ شَانِي͏ٔ͏َكَ هُوَ الْاَبْتَرُ ۝٣ࣖ","transliterationEn":"Inna shaani'aka huwal abtar","translationBnTaisirul":"(তোমার নাম-চিহ্ন কোন দিন মুছবে না, বরং) তোমার প্রতি বিদ্বেষ পোষণকারীরাই নাম চিহ্নহীন- নির্মূল।"}]
