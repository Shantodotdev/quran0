[{"verseKey":"101:1","arabicIndopak":"اَلْقَارِعَةُ ۝١ۙ","transliterationEn":"Al-qaari'ah","translationBnTaisirul":"মহা বিপদ"},{"verseKey":"101:2","arabicIndopak":"مَا الْقَارِعَةُ ۝٢ۚ","transliterationEn":"Mal qaariah","translationBnTaisirul":"কী সেই মহা বিপদ?"},{"verseKey":"101:3","arabicIndopak":"وَمَا͏ٓ اَدْرٰىكَ مَا الْقَارِعَةُ ۝٣ؕ","transliterationEn":"Wa-maa adraaka mal qaari'ah","translationBnTaisirul":"মহা বিপদ সম্পর্কে তুমি কী জান?"},{"verseKey":"101:4","arabicIndopak":"يَوْمَ يَكُوْنُ النَّاسُ كَالْفَرَاشِ الْمَبْثُوْثِ ۝٤ۙ","transliterationEn":"Yauma ya-koonun naasu kal-farashil mabthooth","translationBnTaisirul":"সে দিন মানুষ হবে বিক্ষিপ্ত পতঙ্গের মত"},{"verseKey":"101:5","arabicIndopak":"وَتَكُوْنُ الْجِبَالُ كَالْعِهْنِ الْمَنْفُوْشِ ۝٥ؕ","transliterationEn":"Wa-ta-koonul jibalu kal-'ihnil manfoosh","translationBnTaisirul":"আর পর্বতগুলো হবে ধুনা রঙ্গিন পশমের মত।"},{"verseKey":"101:6","arabicIndopak":"فَاَمَّا مَنْ ثَقُلَتْ مَوَازِيْنُهٗ ۝٦ۙ","transliterationEn":"Fa-amma man thaqulat mawa-zeenuh","translationBnTaisirul":"অতঃপর যার (সৎ কর্মের) পাল্লা ভারি হবে।"},{"verseKey":"101:7","arabicIndopak":"فَهُوَ فِيْ عِيْشَةٍ رَّاضِيَةٍ ۝٧ؕ","transliterationEn":"Fahuwa fee 'ishatir raadiyah","translationBnTaisirul":"সে সুখী জীবন যাপন করবে।"},{"verseKey":"101:8","arabicIndopak":"وَاَمَّا مَنْ خَفَّتْ مَوَازِيْنُهٗ ۝٨ۙ","transliterationEn":"Wa-amma man khaffat mawa-zeenuh","translationBnTaisirul":"আর যার (সৎকর্মের) পাল্লা হালকা হবে,"},{"verseKey":"101:9","arabicIndopak":"فَاُمُّهٗ هَاوِيَةٌ ۝٩ؕ","transliterationEn":"Fa-ummuhu haawiyah","translationBnTaisirul":"(জাহান্নামের) অতলস্পর্শী গর্তই হবে তার বাসস্থান।"},{"verseKey":"101:10","arabicIndopak":"وَمَا͏ٓ اَدْرٰىكَ مَا هِيَهْ ۝١٠ؕ","transliterationEn":"Wa-maa adraaka maa hiyah","translationBnTaisirul":"তুমি কি জান তা কী?"},{"verseKey":"101:11","arabicIndopak":"نَارٌ حَامِيَةٌ ۝١١ࣖ","transliterationEn":"Naarun hamiyah","translationBnTaisirul":"জ্বলন্ত আগুন।"}]
