[{"verseKey":"80:1","arabicIndopak":"عَبَسَ وَتَوَلّٰٓي ۝١ۙ","transliterationEn":"Abasa Wa-tawallaa","translationBnTaisirul":"(নবী) মুখ ভার করল আর মুখ ঘুরিয়ে নিল।"},{"verseKey":"80:2","arabicIndopak":"اَنْ جَا࢜ءَهُ الْاَعْمٰى ۝٢ؕ","transliterationEn":"An jaa-ahul 'a-maa","translationBnTaisirul":"(কারণ সে যখন কুরায়শ সরদারদের সাথে আলোচনায় রত ছিল তখন) তার কাছে এক অন্ধ ব্যক্তি আসল।"},{"verseKey":"80:3","arabicIndopak":"وَمَا يُدْرِيْكَ لَعَلَّهٗ يَزَّكّٰٓي ۝٣ۙ","transliterationEn":"Wa-maa yudreeka la'allahu yaz-zakkaa","translationBnTaisirul":"(হে নবী!) তুমি কি জান, সে হয়ত পরিশুদ্ধ হত।"},{"verseKey":"80:4","arabicIndopak":"اَوْ يَذَّكَّرُ فَتَنْفَعَهُ الذِّكْرٰى ۝٤ؕ","transliterationEn":"Au yaz-zak-karu fatanfa-'ahuz zikraa","translationBnTaisirul":"কিংবা উপদেশ গ্রহণ করত, ফলে উপদেশ তার উপকারে লাগত।"},{"verseKey":"80:5","arabicIndopak":"اَمَّا مَنِ اسْتَغْنٰى ۝٥ۙ","transliterationEn":"Amma manis taghnaa","translationBnTaisirul":"পক্ষান্তরে যে পরোয়া করে না,"},{"verseKey":"80:6","arabicIndopak":"فَاَنْتَ لَهٗ تَصَدّٰى ۝٦ؕ","transliterationEn":"Fa-anta lahu tasaddaa","translationBnTaisirul":"তার প্রতি তুমি মনোযোগ দিচ্ছ।"},{"verseKey":"80:7","arabicIndopak":"وَمَا عَلَيْكَ اَلَّا يَزَّكّٰى ۝٧ؕ","transliterationEn":"Wa-ma 'alaika allaa yaz-zakka","translationBnTaisirul":"সে পরিশুদ্ধ না হলে তোমার উপর কোন দোষ নেই।"},{"verseKey":"80:8","arabicIndopak":"وَاَمَّا مَنْ جَا࢜ءَكَ يَسْعٰى ۝٨ۙ","transliterationEn":"Wa-amma man jaa-aka yas'a","translationBnTaisirul":"পক্ষান্তরে যে লোক তোমার কাছে ছুটে আসল।"},{"verseKey":"80:9","arabicIndopak":"وَهُوَ يَخْشٰى ۝٩ۙ","transliterationEn":"Wahuwa yakhshaa","translationBnTaisirul":"আর সে ভয়ও করে,"},{"verseKey":"80:10","arabicIndopak":"فَاَنْتَ عَنْهُ تَلَهّٰى ۝١٠ۚ","transliterationEn":"Fa-anta 'anhu talah-haa","translationBnTaisirul":"তুমি তার প্রতি অমনোযোগী হলে।"},{"verseKey":"80:11","arabicIndopak":"كَلَّا͏ٓ اِنَّهَا تَذْكِرَةٌ ۝١١ۚ","transliterationEn":"Kalla innaha tazkirah","translationBnTaisirul":"না, এটা মোটেই ঠিক নয়, এটা তো উপদেশ বাণী,"},{"verseKey":"80:12","arabicIndopak":"فَمَنْ شَا࢜ءَ ذَكَرَهٗ ۝١٢ۘ","transliterationEn":"Faman shaa-a zakarah","translationBnTaisirul":"কাজেই যার ইচ্ছে তা স্মরণে রাখবে,"},{"verseKey":"80:13","arabicIndopak":"فِيْ صُحُفٍ مُّكَرَّمَةٍ ۝١٣ۙ","transliterationEn":"Fi suhufim mukar-rama","translationBnTaisirul":"(এটা লিপিবদ্ধ আছে) মর্যাদাসম্পন্ন কিতাবসমূহে"},{"verseKey":"80:14","arabicIndopak":"مَّرْفُوْعَةٍ مُّطَهَّرَةٍۭ ۝١٤ۙ","transliterationEn":"Marfoo'atim mutah-hara","translationBnTaisirul":"সমুন্নত, পবিত্র।"},{"verseKey":"80:15","arabicIndopak":"بِاَيْدِيْ سَفَرَةٍ ۝١٥ۙ","transliterationEn":"Bi'aidee safara","translationBnTaisirul":"(এমন) লেখকদের হাতে"},{"verseKey":"80:16","arabicIndopak":"كِرَامٍۭ بَرَرَةٍ ۝١٦ؕ","transliterationEn":"Kiraamim bararah","translationBnTaisirul":"(যারা) মহা সম্মানিত পূত-পবিত্র।"},{"verseKey":"80:17","arabicIndopak":"قُتِلَ الْاِنْسَانُ مَا͏ٓ اَكْفَرَهٗ ۝١٧ؕ","transliterationEn":"Qutilal insanu maa akfarah","translationBnTaisirul":"মানুষ ধ্বংস হোক! কোন্ জিনিস তাকে সত্য প্রত্যাখ্যানে উদ্বুদ্ধ করল?"},{"verseKey":"80:18","arabicIndopak":"مِنْ اَيِّ شَيْءٍ خَلَقَهٗ ۝١٨ؕ","transliterationEn":"Min aiyyi shai-in Khalaqa","translationBnTaisirul":"আল্লাহ তাকে কোন বস্তু হতে সৃষ্টি করেছেন?"},{"verseKey":"80:19","arabicIndopak":"مِنْ نُّطْفَةٍؕ خَلَقَهٗ فَقَدَّرَهٗ ۝١٩ۙ","transliterationEn":"Min nutfatin khalaqahoo faqaddarah","translationBnTaisirul":"শুক্রবিন্দু হতে। তিনি তাকে সৃষ্টি করেছেন, অতঃপর তাকে পরিমিতভাবে গড়ে তুলেছেন।"},{"verseKey":"80:20","arabicIndopak":"ثُمَّ السَّبِيْلَ يَسَّرَهٗ ۝٢٠ۙ","transliterationEn":"Thummas sabeela yas-sarah","translationBnTaisirul":"অতঃপর তিনি (উপায়-উপকরণ ও প্রয়োজনীয় দ্রব্যসামগ্রী দিয়ে জীবনে চলার জন্য) তার পথ সহজ করে দিয়েছেন।"},{"verseKey":"80:21","arabicIndopak":"ثُمَّ اَمَاتَهٗ فَاَقْبَرَهٗ ۝٢١ۙ","transliterationEn":"Thumma amatahu fa-aqbarah","translationBnTaisirul":"অতঃপর তার মৃত্যু ঘটান এবং তাকে কবরস্থ করেন।"},{"verseKey":"80:22","arabicIndopak":"ثُمَّ اِذَا شَا࢜ءَ اَنْشَرَهٗ ۝٢٢ؕ","transliterationEn":"Thumma iza shaa-a ansharah","translationBnTaisirul":"অতঃপর যখন তিনি চাইবেন তাকে আবার জীবিত করবেন।"},{"verseKey":"80:23","arabicIndopak":"كَلَّا لَمَّا يَقْضِ مَا͏ٓ اَمَرَهٗ ۝٢٣ؕ","transliterationEn":"Kalla lamma yaqdi maa amarah","translationBnTaisirul":"না, মোটেই না, আল্লাহ তাকে যে নির্দেশ দিয়ে ছিলেন তা সে এখনও পূর্ণ করেনি।"},{"verseKey":"80:24","arabicIndopak":"فَلْيَنْظُرِ الْاِنْسَانُ اِلٰى طَعَامِهٖٓ ۝٢٤ۙ","transliterationEn":"Falyanzuril insanu ilaa ta-amih","translationBnTaisirul":"মানুষ তার খাদ্যের ব্যপারটাই ভেবে দেখুক না কেন।"},{"verseKey":"80:25","arabicIndopak":"اَنَّا صَبَبْنَا الْمَا࢜ءَ صَبًّا ۝٢٥ۙ","transliterationEn":"Anna sabab nalmaa-a sabba","translationBnTaisirul":"আমি প্রচুর পানি ঢালি,"},{"verseKey":"80:26","arabicIndopak":"ثُمَّ شَقَقْنَا الْاَرْضَ شَقًّا ۝٢٦ۙ","transliterationEn":"Thumma sha-qaqnal arda shaqqa","translationBnTaisirul":"তারপর যমীনকে বিদীর্ণ করে দেই,"},{"verseKey":"80:27","arabicIndopak":"فَاَنۢ͏ْبَتْنَا فِيْهَا حَبًّا ۝٢٧ۙ","transliterationEn":"Fa-ambatna feeha habba","translationBnTaisirul":"অতঃপর তাতে আমি উৎপন্ন করি-শস্য,"},{"verseKey":"80:28","arabicIndopak":"وَّعِنَبًا وَّقَضْبًا ۝٢٨ۙ","transliterationEn":"Wa-'inabaw wa-qadba","translationBnTaisirul":"আঙ্গুর, তাজা শাক-শব্জী,"},{"verseKey":"80:29","arabicIndopak":"وَّزَيْتُوْنًا وَّنَخْلًا ۝٢٩ۙ","transliterationEn":"Wa-zaitoonaw wanakh-la'","translationBnTaisirul":"যয়তূন, খেজুর,"},{"verseKey":"80:30","arabicIndopak":"وَّحَدَا࢜ىِٕقَ غُلْبًا ۝٣٠ۙ","transliterationEn":"Wa-hadaa-iqa ghulba","translationBnTaisirul":"আর ঘন বৃক্ষ পরিপূর্ণ বাগবাগিচা,"},{"verseKey":"80:31","arabicIndopak":"وَّفَاكِهَةً وَّاَبًّا ۝٣١ۙ","transliterationEn":"Wa-faki-hataw wa-abba","translationBnTaisirul":"আর নানান জাতের ফল আর ঘাস-লতাপাতা।"},{"verseKey":"80:32","arabicIndopak":"مَّتَاعًا لَّكُمْ وَلِاَنْعَامِكُمْ ۝٣٢ؕ","transliterationEn":"Mata'al lakum Wa-li-an'amikum","translationBnTaisirul":"তোমাদের আর তোমাদের গৃহপালিত পশুগুলোর ভোগের জন্য।"},{"verseKey":"80:33","arabicIndopak":"فَاِذَا جَا࢜ءَتِ الصَّا࢜خَّةُ ۝٣٣ؗ","transliterationEn":"Faiza jaa-atis saakhah","translationBnTaisirul":"অবশেষে যখন কান-ফাটানো শব্দ আসবে;"},{"verseKey":"80:34","arabicIndopak":"يَوْمَ يَفِرُّ الْمَرْءُ مِنْ اَخِيْهِ ۝٣٤ۙ","transliterationEn":"Yauma yafir-rul mar-u min akheeh","translationBnTaisirul":"সেদিন মানুষ পালিয়ে যাবে তার ভাই থেকে,"},{"verseKey":"80:35","arabicIndopak":"وَاُمِّهٖ وَاَبِيْهِ ۝٣٥ۙ","transliterationEn":"Wa-ummihee Wa-abeeh","translationBnTaisirul":"তার মা, তার বাপ,"},{"verseKey":"80:36","arabicIndopak":"وَصَاحِبَتِهٖ وَبَنِيْهِ ۝٣٦ؕ","transliterationEn":"Wa-sahi-batihee Wa-baneeh","translationBnTaisirul":"তার স্ত্রী ও তার সন্তান থেকে,"},{"verseKey":"80:37","arabicIndopak":"لِكُلِّ امْرِي͏ٔ͏ٍ مِّنْهُمْ يَوْمَىِٕذٍ شَاْنٌ يُّغْنِيْهِ ۝٣٧ؕ","transliterationEn":"Likul limri-im minhum yawmaa-izin shaa-nuy yughneeh","translationBnTaisirul":"সেদিন তাদের প্রত্যেকেই নিজেকে নিয়ে ব্যতিব্যস্ত থাকবে।"},{"verseKey":"80:38","arabicIndopak":"وُجُوْهٌ يَّوْمَىِٕذٍ مُّسْفِرَةٌ ۝٣٨ۙ","transliterationEn":"Wujoo-huny yauma-izim musfira","translationBnTaisirul":"সেদিন কতক মুখ উজ্জ্বল হবে,"},{"verseKey":"80:39","arabicIndopak":"ضَاحِكَةٌ مُّسْتَبْشِرَةٌ ۝٣٩ۚ","transliterationEn":"Dahi-katum mustab-shirah","translationBnTaisirul":"সহাস্য, উৎফুল্ল।"},{"verseKey":"80:40","arabicIndopak":"وَوُجُوْهٌ يَّوْمَىِٕذٍ عَلَيْهَا غَبَرَةٌ ۝٤٠ۙ","transliterationEn":"Wa-wujoohuy yauma-izin 'alaiha ghabara","translationBnTaisirul":"সেদিন কতক মুখ হবে ধূলিমলিন।"},{"verseKey":"80:41","arabicIndopak":"تَرْهَقُهَا قَتَرَةٌ ۝٤١ؕ","transliterationEn":"Tarhaquha qatarah","translationBnTaisirul":"কালিমা ওগুলোকে আচ্ছন্ন করবে।"},{"verseKey":"80:42","arabicIndopak":"اُولٰ࢜ىِٕكَ هُمُ الْكَفَرَةُ الْفَجَرَةُ ۝٤٢ࣖ","transliterationEn":"Ulaa-ika humul kafa-ratul fajarah","translationBnTaisirul":"তারাই আল্লাহকে প্রত্যাখ্যানকারী, পাপাচারী।"}]
