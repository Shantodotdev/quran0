[{"verseKey":"113:1","arabicIndopak":"قُلْ اَعُوْذُ بِرَبِّ الْفَلَقِ ۝١ۙ","transliterationEn":"Qul a'oozu bi-rabbil falaq","translationBnTaisirul":"বল, ‘আমি আশ্রয় চাচ্ছি সকাল বেলার রব-এর,"},{"verseKey":"113:2","arabicIndopak":"مِنْ شَرِّ مَا خَلَقَ ۝٢ۙ","transliterationEn":"Min sharri maa khalaq","translationBnTaisirul":"তিনি যা সৃষ্টি করেছেন তার অনিষ্ট হতে,"},{"verseKey":"113:3","arabicIndopak":"وَمِنْ شَرِّ غَاسِقٍ اِذَا وَقَبَ ۝٣ۙ","transliterationEn":"Wa-min sharri ghaasiqin izaa waqab","translationBnTaisirul":"আর অন্ধকার রাতের অনিষ্ট হতে যখন তা আচ্ছন্ন হয়ে যায়।"},{"verseKey":"113:4","arabicIndopak":"وَمِنْ شَرِّ النَّفّٰثٰتِ فِي الْعُقَدِ ۝٤ۙ","transliterationEn":"Wa-min sharrin naffaa-saati fil 'uqad","translationBnTaisirul":"এবং (জাদু করার উদ্দেশ্যে) গিরায় ফুৎকারকারিণীদের অনিষ্ট হতে,"},{"verseKey":"113:5","arabicIndopak":"وَمِنْ شَرِّ حَاسِدٍ اِذَا حَسَدَ ۝٥ࣖ","transliterationEn":"Wa-min sharri haasidin izaa hasad","translationBnTaisirul":"এবং হিংসুকের অনিষ্ট হতে, যখন সে হিংসা করে।"}]
