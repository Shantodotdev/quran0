[{"verseKey":"114:1","arabicIndopak":"قُلْ اَعُوْذُ بِرَبِّ النَّاسِ ۝١ۙ","transliterationEn":"Qul a'oozu birabbin naas","translationBnTaisirul":"বল, ‘আমি আশ্রয় চাচ্ছি মানুষের প্রতিপালকের,"},{"verseKey":"114:2","arabicIndopak":"مَلِكِ النَّاسِ ۝٢ۙ","transliterationEn":"Malikin naas","translationBnTaisirul":"মানুষের অধিপতির,"},{"verseKey":"114:3","arabicIndopak":"اِلٰهِ النَّاسِ ۝٣ۙ","transliterationEn":"Ilaahin naas","translationBnTaisirul":"মানুষের প্রকৃত ইলাহর,"},{"verseKey":"114:4","arabicIndopak":"مِنْ شَرِّ الْوَسْوَاسِ࣢ۙ الْخَنَّاسِ ۝٤ࣕۙ","transliterationEn":"Min sharril waswaasil khannaas","translationBnTaisirul":"যে নিজেকে লুকিয়ে রেখে বার বার এসে কুমন্ত্রণা দেয় তার অনিষ্ট হতে,"},{"verseKey":"114:5","arabicIndopak":"الَّذِيْ يُوَسْوِسُ فِيْ صُدُوْرِ النَّاسِ ۝٥ۙ","transliterationEn":"Allazee yuwaswisu fee sudoorin naas","translationBnTaisirul":"যে কুমন্ত্রণা দেয় মানুষের অন্তরে"},{"verseKey":"114:6","arabicIndopak":"مِنَ الْجِنَّةِ وَالنَّاسِ ۝٦ࣖ","transliterationEn":"Minal jinnati wannaas","translationBnTaisirul":"(এই কুমন্ত্রণাদাতা হচ্ছে) জিন্নের মধ্য হতে এবং মানুষের মধ্য হতে।"}]
