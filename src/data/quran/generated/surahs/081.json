[{"verseKey":"81:1","arabicIndopak":"اِذَا الشَّمْسُ كُوِّرَتْ ۝١ࣕۙ","transliterationEn":"Izash shamsu kuwwirat","translationBnTaisirul":"যখন সূর্যকে গুটিয়ে নেয়া হবে"},{"verseKey":"81:2","arabicIndopak":"وَاِذَا النُّجُوْمُ انْكَدَرَتْ ۝٢ࣕۙ","transliterationEn":"Wa-izan nujoomun kadarat","translationBnTaisirul":"আর তারকাগুলো যখন তাদের উজ্জ্বলতা হারিয়ে খসে পড়বে।"},{"verseKey":"81:3","arabicIndopak":"وَاِذَا الْجِبَالُ سُيِّرَتْ ۝٣ࣕۙ","transliterationEn":"Wa-izal jibaalu suyyirat","translationBnTaisirul":"পর্বতগুলোকে যখন চলমান করা হবে,"},{"verseKey":"81:4","arabicIndopak":"وَاِذَا الْعِشَارُ عُطِّلَتْ ۝٤ࣕۙ","transliterationEn":"Wa-izal 'ishaaru 'uttilat","translationBnTaisirul":"যখন দশ মাসের গর্ভবতী উটনিগুলোকে অযত্নে পরিত্যাগ করা হবে,"},{"verseKey":"81:5","arabicIndopak":"وَاِذَا الْوُحُوْشُ حُشِرَتْ ۝٥ࣕۙ","transliterationEn":"Wa-izal wuhooshu hushirat","translationBnTaisirul":"যখন বনের জন্তু জানোয়ারকে (বন থেকে গুটিয়ে এনে লোকালয়ে) একত্রিত করা হবে,"},{"verseKey":"81:6","arabicIndopak":"وَاِذَا الْبِحَارُ سُجِّرَتْ ۝٦ࣕۙ","transliterationEn":"Wa-izal bihaaru sujjirat","translationBnTaisirul":"যখন সমুদ্রগুলোকে প্রজ্জ্বলিত করে উত্তাল করা হবে।"},{"verseKey":"81:7","arabicIndopak":"وَاِذَا النُّفُوْسُ زُوِّجَتْ ۝٧ࣕۙ","transliterationEn":"Wa-izan nufoosu zuwwijat","translationBnTaisirul":"যখন দেহের সঙ্গে আত্মাগুলোকে আবার জুড়ে দেয়া হবে,"},{"verseKey":"81:8","arabicIndopak":"وَاِذَا الْمَوْءٗدَةُ سُىِٕلَتْ ۝٨ࣕۙ","transliterationEn":"Wa-izal maw'oodatu su'ilat","translationBnTaisirul":"যখন জীবন্ত পুঁতে-ফেলা কন্যা-শিশুকে জিজ্ঞেস করা হবে,"},{"verseKey":"81:9","arabicIndopak":"بِاَيِّ ذَنۢ͏ْبٍ قُتِلَتْ ۝٩ۚ","transliterationEn":"Bi-ayyi zambin qutilat","translationBnTaisirul":"কোন্ অপরাধে তাকে হত্যা করা হয়েছে?"},{"verseKey":"81:10","arabicIndopak":"وَاِذَا الصُّحُفُ نُشِرَتْ ۝١٠ࣕۙ","transliterationEn":"Wa-izas suhufu nushirat","translationBnTaisirul":"যখন ‘আমালনামাগুলো খুলে ধরা হবে,"},{"verseKey":"81:11","arabicIndopak":"وَاِذَا السَّمَا࢜ءُ كُشِطَتْ ۝١١ࣕۙ","transliterationEn":"Wa-izas samaaa'u kushitat","translationBnTaisirul":"যখন আসমানের পর্দা সরিয়ে ফেলা হবে।"},{"verseKey":"81:12","arabicIndopak":"وَاِذَا الْجَحِيْمُ سُعِّرَتْ ۝١٢ࣕۙ","transliterationEn":"Wa-izal jaheemu su'-'irat","translationBnTaisirul":"যখন জাহান্নামকে উসকে দেয়া হবে,"},{"verseKey":"81:13","arabicIndopak":"وَاِذَا الْجَنَّةُ اُزْلِفَتْ ۝١٣ࣕۙ","transliterationEn":"Wa-izal jannatu uzlifat","translationBnTaisirul":"আর জান্নাতকে নিকটে আনা হবে,"},{"verseKey":"81:14","arabicIndopak":"عَلِمَتْ نَفْسٌ مَّا͏ٓ اَحْضَرَتْ ۝١٤ؕ","transliterationEn":"Alimat nafsum maaa ahdarat","translationBnTaisirul":"তখন প্রত্যেক ব্যক্তি জানতে পারবে সে কী (সঙ্গে) নিয়ে এসেছে।"},{"verseKey":"81:15","arabicIndopak":"فَلَا͏ٓ اُقْسِمُ بِالْخُنَّسِ ۝١٥ۙ","transliterationEn":"Falaaa uqsimu bil-khunnas","translationBnTaisirul":"আমি শপথ করছি (গ্রহের) যা পেছনে সরে যায়,"},{"verseKey":"81:16","arabicIndopak":"الْجَوَارِ الْكُنَّسِ ۝١٦ۙ","transliterationEn":"Al-jawaaril kunnas","translationBnTaisirul":"চলে ও লুকিয়ে যায়,"},{"verseKey":"81:17","arabicIndopak":"وَالَّيْلِ اِذَا عَسْعَسَ ۝١٧ۙ","transliterationEn":"Wallaili izaa 'as'as","translationBnTaisirul":"শপথ রাতের যখন তা বিদায় নেয়"},{"verseKey":"81:18","arabicIndopak":"وَالصُّبْحِ اِذَا تَنَفَّسَ ۝١٨ۙ","transliterationEn":"Wassubhi izaa tanaffas","translationBnTaisirul":"আর ঊষার যখন তা নিঃশ্বাস ফেলে অন্ধকারকে বের করে দেয়,"},{"verseKey":"81:19","arabicIndopak":"اِنَّهٗ لَقَوْلُ رَسُوْلٍ كَرِيْمٍ ۝١٩ۙ","transliterationEn":"Innahoo laqawlu rasoolin kareem","translationBnTaisirul":"এ কুরআন নিশ্চয়ই সম্মানিত রসূলের (অর্থাৎ জিবরাঈলের) আনীত বাণী।"},{"verseKey":"81:20","arabicIndopak":"ذِيْ قُوَّةٍ عِنْدَ ذِي الْعَرْشِ مَكِيْنٍ ۝٢٠ۙ","transliterationEn":"Zee quwwatin 'inda zil 'arshi makeen","translationBnTaisirul":"যে শক্তিশালী, ‘আরশের মালিক (আল্লাহ)’র নিকট মর্যাদাশীল।"},{"verseKey":"81:21","arabicIndopak":"مُّطَاعٍ ثَمَّ اَمِيْنٍ ۝٢١ؕ","transliterationEn":"Mutaa'in samma ameen","translationBnTaisirul":"সেখানে মান্য ও বিশ্বস্ত।"},{"verseKey":"81:22","arabicIndopak":"وَمَا صَاحِبُكُمْ بِمَجْنُوْنٍ ۝٢٢ۚ","transliterationEn":"Wa-maa saahibukum bimajnoon","translationBnTaisirul":"(ওহে মাক্কাবাসী!) তোমাদের সঙ্গী (মুহাম্মাদ) পাগল নয়।"},{"verseKey":"81:23","arabicIndopak":"وَلَقَدْ رَاٰهُ بِالْاُفُقِ الْمُبِيْنِ ۝٢٣ۚ","transliterationEn":"Wa-laqad ra-aahu bilufuqil mubeen","translationBnTaisirul":"সে সেই বাণী বাহককে সুস্পষ্ট দিগন্তে দেখেছে,"},{"verseKey":"81:24","arabicIndopak":"وَمَا هُوَ عَلَي الْغَيْبِ بِضَنِيْنٍ ۝٢٤ۚ","transliterationEn":"Wa-maa huwa 'alal ghaibi bidaneen","translationBnTaisirul":"সে গায়বের (জ্ঞান মানুষের কাছে পৌঁছে দেয়ার) ব্যাপারে কৃপণতা করে না।"},{"verseKey":"81:25","arabicIndopak":"وَمَا هُوَ بِقَوْلِ شَيْطٰنٍ رَّجِيْمٍ ۝٢٥ۙ","transliterationEn":"Wa-maa huwa biqawli shaitaanir rajeem","translationBnTaisirul":"আর তা কোন অভিশপ্ত শয়ত্বানের বাণী নয়।"},{"verseKey":"81:26","arabicIndopak":"فَاَيْنَ تَذْهَبُوْنَ ۝٢٦ؕ","transliterationEn":"Fa-ayna tazhaboon","translationBnTaisirul":"কাজেই তোমরা (সত্যকে প্রত্যাখ্যান করে) কোথায় চলেছ?"},{"verseKey":"81:27","arabicIndopak":"اِنْ هُوَ اِلَّا ذِكْرٌ لِّلْعٰلَمِيْنَ ۝٢٧ۙ","transliterationEn":"In huwa illaa zikrul lil'aalameen","translationBnTaisirul":"এটা তো কেবল বিশ্ববাসীদের জন্য উপদেশ।"},{"verseKey":"81:28","arabicIndopak":"لِمَنْ شَا࢜ءَ مِنْكُمْ اَنْ يَّسْتَقِيْمَ ۝٢٨ؕ","transliterationEn":"Liman shaaa'a minkum ai yastaqeem","translationBnTaisirul":"তার জন্য- যে তোমাদের মধ্যে সরল সঠিক পথে চলতে চায়।"},{"verseKey":"81:29","arabicIndopak":"وَمَا تَشَا࢜ءُوْنَ اِلَّا͏ٓ اَنْ يَّشَا࢜ءَ اللّٰهُ رَبُّ الْعٰلَمِيْنَ ۝٢٩ࣖ","transliterationEn":"Wa-maa tashaaa'oona illaaa ai yashaaa-'al laahu Rabbul 'Aalameen","translationBnTaisirul":"তোমরা ইচ্ছে কর না যদি বিশ্বজগতের প্রতিপালক আল্লাহ ইচ্ছে না করেন।"}]
