[{"verseKey":"96:1","arabicIndopak":"اِقْرَاْ بِاسْمِ رَبِّكَ الَّذِيْ خَلَقَ ۝١ۚ","transliterationEn":"Iqra bismi rab-bikal lazee khalaq","translationBnTaisirul":"পাঠ কর তোমার প্রতিপালকের নামে যিনি সৃষ্টি করেছেন,"},{"verseKey":"96:2","arabicIndopak":"خَلَقَ الْاِنْسَانَ مِنْ عَلَقٍ ۝٢ۚ","transliterationEn":"Khalaqal insaana min 'alaq","translationBnTaisirul":"সৃষ্টি করেছেন মানুষকে জমাট-বাঁধা রক্তপিন্ড হতে।"},{"verseKey":"96:3","arabicIndopak":"اِقْرَاْ وَرَبُّكَ الْاَكْرَمُ ۝٣ۙ","transliterationEn":"Iqra Wa-rab-bukal akram","translationBnTaisirul":"পাঠ কর, আর তোমার রব বড়ই অনুগ্রহশীল।"},{"verseKey":"96:4","arabicIndopak":"الَّذِيْ عَلَّمَ بِالْقَلَمِ ۝٤ۙ","transliterationEn":"Al-lazee 'allama bil-qalam","translationBnTaisirul":"যিনি শিক্ষা দিয়েছেন কলম দিয়ে,"},{"verseKey":"96:5","arabicIndopak":"عَلَّمَ الْاِنْسَانَ مَا لَمْ يَعْلَمْ ۝٥ؕ","transliterationEn":"Al-lamal insaana ma lam y'alam","translationBnTaisirul":"শিক্ষা দিয়েছেন মানুষকে যা সে জানত না,"},{"verseKey":"96:6","arabicIndopak":"كَلَّا͏ٓ اِنَّ الْاِنْسَانَ لَيَطْغٰٓي ۝٦ۙ","transliterationEn":"Kallaa innal insaana layatghaa","translationBnTaisirul":"না (এমন আচরণ করা) মোটেই ঠিক নয়, মানুষ অবশ্যই সীমালঙ্ঘন করে,"},{"verseKey":"96:7","arabicIndopak":"اَنْ رَّاٰهُ اسْتَغْنٰي ۝٧ؕ","transliterationEn":"Ar-ra aahus taghnaa","translationBnTaisirul":"কারণ, সে নিজেকে অভাবমুক্ত মনে করে,"},{"verseKey":"96:8","arabicIndopak":"اِنَّ اِلٰي رَبِّكَ الرُّجْعٰي ۝٨ؕ","transliterationEn":"Innna ilaa rabbikar ruj'aa","translationBnTaisirul":"নিঃসন্দেহে (সকলকে) ফিরে যেতে হবে তোমার প্রতিপালকের দিকে।"},{"verseKey":"96:9","arabicIndopak":"اَرَءَيْتَ الَّذِيْ يَنْهٰي ۝٩ۙ","transliterationEn":"Ara-aital lazee yanhaa","translationBnTaisirul":"তুমি কি তাকে (অর্থাৎ আবূ জাহলকে) দেখেছ যে নিষেধ করে,"},{"verseKey":"96:10","arabicIndopak":"عَبْدًا اِذَا صَلّٰي ۝١٠ؕ","transliterationEn":"Abdan iza sallaa","translationBnTaisirul":"এক বান্দাহকে [অর্থাৎ রসূলুল্লাহ (সা.)-কে] যখন সে নামায আদায় করতে থাকে?"},{"verseKey":"96:11","arabicIndopak":"اَرَءَيْتَ اِنْ كَانَ عَلَي الْهُدٰٓي ۝١١ۙ","transliterationEn":"Ara-aita in kana 'alal hudaa","translationBnTaisirul":"তুমি কি ভেবে দেখেছ (যাকে নিষেধ করা হচ্ছে) সে যদি সৎ পথে থাকে,"},{"verseKey":"96:12","arabicIndopak":"اَوْ اَمَرَ بِالتَّقْوٰي ۝١٢ؕ","transliterationEn":"Au amara bit-taqwaa","translationBnTaisirul":"আর তাকওয়া অবলম্বনের নির্দেশ দেয় (তাহলে তার এ কাজগুলো কেমন মনে কর?)"},{"verseKey":"96:13","arabicIndopak":"اَرَءَيْتَ اِنْ كَذَّبَ وَتَوَلّٰي ۝١٣ؕ","transliterationEn":"Ara-aita in kaz-zaba Wa-ta-walla","translationBnTaisirul":"তোমার কী ধারণা যদি সে (অর্থাৎ নিষেধকারী ব্যক্তি) সত্যকে অস্বীকার করে আর মুখ ফিরিয়ে নেয় (তাহলে তার এ কাজ কেমন মনে কর?)"},{"verseKey":"96:14","arabicIndopak":"اَلَمْ يَعْلَمْ بِاَنَّ اللّٰهَ يَرٰي ۝١٤ؕ","transliterationEn":"Alam y'alam bi-an-nal lahaa yaraa","translationBnTaisirul":"সে কি জানে না যে, আল্লাহ দেখেন?"},{"verseKey":"96:15","arabicIndopak":"كَلَّا لَىِٕنْ لَّمْ يَنْتَهِ࣢ۙ لَنَسْفَعًاۢ بِالنَّاصِيَةِ ۝١٥ۙ","transliterationEn":"Kalla la-il lam yantahi la-nasfa'am bin-nasiyah","translationBnTaisirul":"না, (সে যা করতে চায়) তা কক্ষনো করতে পারবে না, সে যদি বিরত না হয় তাহলে আমি অবশ্যই তার মাথার সামনের চুলগুচ্ছ ধরে হেঁচড়ে নিয়ে যাব-"},{"verseKey":"96:16","arabicIndopak":"نَاصِيَةٍ كَاذِبَةٍ خَاطِي͏ٔ͏َةٍ ۝١٦ۚ","transliterationEn":"Nasiyatin kazi-batin khaatiah","translationBnTaisirul":"মিথ্যাচারী পাপাচারী চুলগুচ্ছ"},{"verseKey":"96:17","arabicIndopak":"فَلْيَدْعُ نَادِيَهٗ ۝١٧ۙ","transliterationEn":"Fal-yad'u naadiyah","translationBnTaisirul":"কাজেই সে তার সভাষদদের ডাকুক।"},{"verseKey":"96:18","arabicIndopak":"سَنَدْعُ الزَّبَانِيَةَ ۝١٨ۙ","transliterationEn":"Sanad-'uz zabaaniyah","translationBnTaisirul":"আমিও ‘আযাবের ফেরেশতাদেরকে ডাকব,"},{"verseKey":"96:19","arabicIndopak":"كَلَّاؕ لَا تُطِعْهُ وَاسْجُدْ وَاقْتَرِبْ ۝١٩ࣛࣖ","transliterationEn":"Kalla; la tuti'hu wasjud waqtarib","translationBnTaisirul":"না, তুমি কক্ষনো তার অনুসরণ করো না, তুমি সাজদাহ কর আর (আল্লাহর) নৈকট্য লাভ কর।[সাজদাহ]"}]
