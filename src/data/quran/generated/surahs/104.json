[{"verseKey":"104:1","arabicIndopak":"وَيْلٌ لِّكُلِّ هُمَزَةٍ لُّمَزَةِ ۝١ۙ","transliterationEn":"Wailul likulli hu-mazatil lumazah","translationBnTaisirul":"দুর্ভোগ এমন প্রত্যেক ব্যক্তির জন্য যে (সামনাসামনি) মানুষের নিন্দা করে আর (অসাক্ষাতে) দুর্নাম করে,"},{"verseKey":"104:2","arabicIndopak":"اࣙلَّذِيْ جَمَعَ مَالًا وَّعَدَّدَهٗ ۝٢ۙ","transliterationEn":"Allazee jama'a maalanw Wa-'addadah","translationBnTaisirul":"যে ধন-সম্পদ জমা করে আর বার বার গণনা করে,"},{"verseKey":"104:3","arabicIndopak":"يَحْسَبُ اَنَّ مَالَهٗٓ اَخْلَدَهٗ ۝٣ۚ","transliterationEn":"Yahsabu anna maalahooo akhladah","translationBnTaisirul":"সে মনে করে যে, তার ধন-সম্পদ চিরকাল তার সাথে থাকবে,"},{"verseKey":"104:4","arabicIndopak":"كَلَّا لَيُنۢ͏ْبَذَنَّ فِي الْحُطَمَةِ ۝٤ؗۖ","transliterationEn":"Kallaa; layumbazanna fil hutamah","translationBnTaisirul":"কক্ষনো না, তাকে অবশ্যই চূর্ণ-বিচূর্ণকারীর মধ্যে নিক্ষেপ করা হবে,"},{"verseKey":"104:5","arabicIndopak":"وَمَا͏ٓ اَدْرٰىكَ مَا الْحُطَمَةُ ۝٥ؕ","transliterationEn":"Wa-maa adraaka mal hutamah","translationBnTaisirul":"তুমি কি জান চূর্ণ-বিচূর্ণকারী কী?"},{"verseKey":"104:6","arabicIndopak":"نَارُ اللّٰهِ الْمُوْقَدَةُ ۝٦ۙ","transliterationEn":"Naarul laahil mooqada","translationBnTaisirul":"তা আল্লাহর প্রজ্জ্বলিত আগুন,"},{"verseKey":"104:7","arabicIndopak":"الَّتِيْ تَطَّلِعُ عَلَي الْاَفْـِٕدَةِ ۝٧ؕ","transliterationEn":"Allatee tattali'u 'alal af'idah","translationBnTaisirul":"যা হৃদয় পর্যন্ত পৌঁছে যাবে।"},{"verseKey":"104:8","arabicIndopak":"اِنَّهَا عَلَيْهِمْ مُّو͏ٔ͏ْصَدَةٌ ۝٨ۙ","transliterationEn":"Innahaa 'alaihim mu'sada","translationBnTaisirul":"তা তাদেরকে চতুর্দিক থেকে পরিবেষ্টন করে রাখবে,"},{"verseKey":"104:9","arabicIndopak":"فِيْ عَمَدٍ مُّمَدَّدَةٍ ۝٩ࣖ","transliterationEn":"Fee 'amadim mumaddadah","translationBnTaisirul":"(লেলিহান অগ্নিশিখার) উঁচু উঁচু স্তম্ভে।"}]
