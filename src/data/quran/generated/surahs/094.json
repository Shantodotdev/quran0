[{"verseKey":"94:1","arabicIndopak":"اَلَمْ نَشْرَحْ لَكَ صَدْرَكَ ۝١ۙ","transliterationEn":"Alam nashrah laka sadrak","translationBnTaisirul":"(হে নবী! ওয়াহীর মাধ্যমে প্রকৃত জ্ঞান ও মানসিক শক্তি দিয়ে) আমি কি তোমার বক্ষদেশকে প্রসারিত করে দেইনি?"},{"verseKey":"94:2","arabicIndopak":"وَوَضَعْنَا عَنْكَ وِزْرَكَ ۝٢ۙ","transliterationEn":"Wa-Wa-d'ana 'anka wizrak","translationBnTaisirul":"আর আমি তোমার হতে সরিয়ে দিয়েছি (সমাজের অনাচার, অশ্লীলতা ও পঙ্কিলতা দেখে তোমার অন্তরে জেগে উঠা দুঃখ, বেদনা, উদ্বেগ ও অস্থিরতার) ভার,"},{"verseKey":"94:3","arabicIndopak":"الَّذِيْٓ اَنْقَضَ ظَهْرَكَ ۝٣ۙ","transliterationEn":"Allazee anqada zahrak","translationBnTaisirul":"যা তোমার কোমরকে ভেঙ্গে দিচ্ছিল।"},{"verseKey":"94:4","arabicIndopak":"وَرَفَعْنَا لَكَ ذِكْرَكَ ۝٤ؕ","transliterationEn":"Wa-raf-'ana laka zikrak","translationBnTaisirul":"এবং আমি (মু’মিনদের যাবতীয় আবশ্যিক ‘ইবাদাত আযান, ইক্বামাত, নামায, খুৎবাহ ইত্যাদির মাধ্যমে) তোমার স্মৃতিকে উচ্চ মর্যাদায় তুলে ধরেছি।"},{"verseKey":"94:5","arabicIndopak":"فَاِنَّ مَعَ الْعُسْرِ يُسْرًا ۝٥ۙ","transliterationEn":"Fa-inna ma'al usri yusra","translationBnTaisirul":"কষ্টের সাথেই স্বস্তি আছে,"},{"verseKey":"94:6","arabicIndopak":"اِنَّ مَعَ الْعُسْرِ يُسْرًا ۝٦ؕ","transliterationEn":"Inna ma'al 'usri yusra","translationBnTaisirul":"নিঃসন্দেহে কষ্টের সাথেই স্বস্তি আছে।"},{"verseKey":"94:7","arabicIndopak":"فَاِذَا فَرَغْتَ فَانْصَبْ ۝٧ۙ","transliterationEn":"Fa-iza faragh-ta fansab","translationBnTaisirul":"কাজেই তুমি যখনই অবসর পাবে, ‘ইবাদাতের কঠোর শ্রমে লেগে যাবে,"},{"verseKey":"94:8","arabicIndopak":"وَاِلٰي رَبِّكَ فَارْغَبْ ۝٨ࣖ","transliterationEn":"Wa-ilaa rabbika far-ghab","translationBnTaisirul":"এবং তোমার রব-এর প্রতি গভীরভাবে মনোযোগ দিবে।"}]
