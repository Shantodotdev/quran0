[{"verseKey":"107:1","arabicIndopak":"اَرَءَيْتَ الَّذِيْ يُكَذِّبُ بِالدِّيْنِ ۝١ؕ","transliterationEn":"Ara-'aytal lazee yukazzibu biddeen","translationBnTaisirul":"তুমি কি তাকে দেখেছ, যে কর্মফল (দিবসকে) অস্বীকার করে?"},{"verseKey":"107:2","arabicIndopak":"فَذٰلِكَ الَّذِيْ يَدُعُّ الْيَتِيْمَ ۝٢ۙ","transliterationEn":"Fazaalikal lazee yadu'ul yateem","translationBnTaisirul":"সে তো সেই (লোক) যে ইয়াতীমকে ধাক্কা দিয়ে সরিয়ে দেয়,"},{"verseKey":"107:3","arabicIndopak":"وَلَا يَحُضُّ عَلٰي طَعَامِ الْمِسْكِيْنِ ۝٣ؕ","transliterationEn":"Wa-la yahuddu 'alaa ta'aamil miskeen","translationBnTaisirul":"এবং মিসকীনকে অন্ন দিতে উৎসাহ দেয় না"},{"verseKey":"107:4","arabicIndopak":"فَوَيْلٌ لِّلْمُصَلِّيْنَ ۝٤ۙ","transliterationEn":"Fa-wailul lil-musalleen","translationBnTaisirul":"অতএব দুর্ভোগ সে সব নামায আদায়কারীর"},{"verseKey":"107:5","arabicIndopak":"الَّذِيْنَ هُمْ عَنْ صَلَاتِهِمْ سَاهُوْنَ ۝٥ۙ","transliterationEn":"Allazeena hum 'an salaatihim saahoon","translationBnTaisirul":"যারা নিজেদের নামাযের ব্যাপারে উদাসীন,"},{"verseKey":"107:6","arabicIndopak":"الَّذِيْنَ هُمْ يُرَا࢜ءُوْنَ ۝٦ۙ","transliterationEn":"Allazeena hum yuraaa'oon","translationBnTaisirul":"যারা লোক দেখানোর জন্য তা করে,"},{"verseKey":"107:7","arabicIndopak":"وَيَمْنَعُوْنَ الْمَاعُوْنَ ۝٧ࣖ","transliterationEn":"Wa-yamna'oonal maa'oon","translationBnTaisirul":"এবং প্রয়োজনীয় গৃহসামগ্রী দানের ছোট খাট সাহায্য করা থেকেও বিরত থাকে।"}]
